<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
    <CheckButton name="OptionsCheckButtonTemplate" virtual="true">
        <Size x="24" y="24"/>
        <Layers>
            <Layer level="ARTWORK">
                <Texture name="$parentNormalTexture" file="Textures/buttons.tga">
                    <Size x="24" y="24"/>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>
                <FontString name="$parentText" inherits="GameFontHighlight">
                    <Anchors>
                        <Anchor point="LEFT" relativePoint="RIGHT">
                            <Offset>
                                <AbsDimension x="5" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <NormalTexture name="$parentNormalTexture" file="Textures/buttons.tga"/>
        <PushedTexture file="Textures/buttons.tga"/>
        <CheckedTexture file="Textures/buttons.tga"/>
        <DisabledCheckedTexture file="Textures/buttons.tga"/>
        <HighlightTexture file="Textures/buttons.tga" alphaMode="ADD"/>
    </CheckButton>

    <Script file="Options.lua"/>
    <Frame name="BeastAndBowOptionsFrame" hidden="true">
        <Scripts>
            <OnLoad>
                self.name = BeastAndBow.L.ADDON_NAME
                self.okay = function(self) end
                self.cancel = function(self) end
                self.default = function(self) end
            </OnLoad>
        </Scripts>
        <Frames>
            <Frame name="$parentHeader">
                <Size y="20"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
						<Offset>
							<AbsDimension x="15" y="-10"/>
						</Offset>
					</Anchor>
                    <Anchor point="RIGHT" relativeTo="$parent" relativePoint="RIGHT">
                        <Offset>
                            <AbsDimension x="-15" y="0"/>
                        </Offset>
                    </Anchor>
				</Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString name="$parentText" inherits="GameFontNormalLarge">
                            <Anchors>
                                <Anchor point="LEFT">
                                    <Offset>
                                        <AbsDimension x="0" y="2"/>
                                    </Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
				<Scripts>
					<OnLoad>
						_G[self:GetName().."Text"]:SetText(BeastAndBow.L.ADDON_NAME)
					</OnLoad>
				</Scripts>
			</Frame>
            
            <CheckButton name="BeastAndBowOptionsFrame_WarningSystem" inherits="OptionsCheckButtonTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parentHeader" relativePoint="BOTTOMLEFT">
                        <Offset>
                            <AbsDimension x="15" y="-15"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnLoad>
                        _G[self:GetName().."Text"]:SetText(BeastAndBow.L.OPTIONS_ENABLE_WARNINGS)
                        self.tooltip = BeastAndBow.L.OPTIONS_ENABLE_WARNINGS_TOOLTIP
                    </OnLoad>
                    <OnClick>
                        BeastAndBow.Options.ToggleWarningSystem(self:GetChecked())
                    </OnClick>
                </Scripts>
            </CheckButton>

            <CheckButton name="BeastAndBowOptionsFrame_ShowFrame" inherits="OptionsCheckButtonTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="BeastAndBowOptionsFrame_WarningSystem" relativePoint="BOTTOMLEFT">
                        <Offset>
                            <AbsDimension x="0" y="-5"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnLoad>
                        _G[self:GetName().."Text"]:SetText(BeastAndBow.L.OPTIONS_SHOW_FRAME)
                        self.tooltip = BeastAndBow.L.OPTIONS_SHOW_FRAME_TOOLTIP
                    </OnLoad>
                    <OnClick>
                        BeastAndBow.Options.ToggleFrame(self:GetChecked())
                    </OnClick>
                </Scripts>
            </CheckButton>

            <CheckButton name="BeastAndBowOptionsFrame_EnableLogging" inherits="OptionsCheckButtonTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="BeastAndBowOptionsFrame_ShowFrame" relativePoint="BOTTOMLEFT">
                        <Offset>
                            <AbsDimension x="0" y="-5"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnLoad>
                        _G[self:GetName().."Text"]:SetText(BeastAndBow.L.OPTIONS_ENABLE_LOGGING)
                        self.tooltip = BeastAndBow.L.OPTIONS_ENABLE_LOGGING_TOOLTIP
                    </OnLoad>
                    <OnClick>
                        BeastAndBow.Options.ToggleLogging(self:GetChecked())
                    </OnClick>
                </Scripts>
            </CheckButton>
        </Frames>
    </Frame>
</Ui>